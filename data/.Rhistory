library(tseries)
library(tidyverse)
library(urca)
# load data
setwd("C:/Users/coleg/OneDrive - UC San Diego/Spring 2026 Courses/Econ 112/HW 5/data")
teams_data <- read.csv("Teams.csv", header = T, sep = ',')
mlb_time_series <- teams_data %>%
filter(yearID >= 1962, yearID <= 2019) %>%
group_by(yearID) %>%
summarise(
total_hr = sum(HR, na.rm = TRUE),
total_k = sum(SO, na.rm = TRUE),
.groups = 'drop'
)
hr_data <- ts(mlb_time_series$total_hr, start = 1962, frequency = 1)
k_data <- ts(mlb_time_series$total_k, start = 1962, frequency = 1)
plot(
hr_data,
type = 'l',
main = "Total MLB Home Runs",
xlab = "Year",
ylab = "Home Runs"
)
plot(
k_data,
type = 'l',
main = "Total MLB Strikeouts",
xlab = "Year",
ylab = "Strikeouts"
)
adf_hr <- ur.df(
hr_data,
type = "trend",
selectlags = "AIC"
)
adf_k <- ur.df(
k_data,
type = "trend",
selectlags = "AIC"
)
summary(adf_hr)
summary(adf_k)
hr_on_k <- lm(hr_data~k_data)
summary(hr_on_k)
hr_on_k_residuals <- residuals(hr_on_k)
adf_residuals <- ur.df(
hr_on_k_residuals,
type = "none",
selectlags = "AIC"
)
summary(adf_residuals)
summary(adf_residuals)
hr_on_k_residuals <- residuals(hr_on_k)
adf_residuals <- ur.df(
hr_on_k_residuals,
type = "none",
selectlags = "AIC"
)
summary(adf_residuals)
# HW 5
# by Cole Geller
library(tidyverse)
library(urca)
# load data
setwd("C:/Users/coleg/OneDrive - UC San Diego/Spring 2026 Courses/Econ 112/HW 5/data")
# Data source: Lahman Baseball Database, Teams.csv.
# The sample begins in 1962, when both MLB leagues generally used a
# 162-game schedule, and ends in 2019 to exclude the shortened 2020 season.
teams_data <- read.csv("Teams.csv", header = TRUE, sep = ',')
mlb_time_series <- teams_data %>%
filter(yearID >= 1962, yearID <= 2019) %>%
group_by(yearID) %>%
summarise(
total_hr = sum(HR, na.rm = TRUE),
total_k = sum(SO, na.rm = TRUE),
.groups = 'drop'
)
hr_data <- ts(mlb_time_series$total_hr, start = 1962, frequency = 1)
k_data <- ts(mlb_time_series$total_k, start = 1962, frequency = 1)
### Q1
# plot data
plot(
hr_data,
type = 'l',
main = "Total MLB Home Runs",
xlab = "Year",
ylab = "Home Runs"
)
plot(
k_data,
type = 'l',
main = "Total MLB Strikeouts",
xlab = "Year",
ylab = "Strikeouts"
)
# test for non-stationarity
adf_hr <- ur.df(
hr_data,
type = "trend",
selectlags = "AIC"
)
adf_k <- ur.df(
k_data,
type = "trend",
selectlags = "AIC"
)
summary(adf_hr)
summary(adf_k)
# For home runs, the ADF tau3 statistic is -3.0356.
# For strikeouts, the ADF tau3 statistic is -2.0199.
# The 1% critical value is -4.04.
#
# Because neither test statistic is more negative than -4.04, I fail to
# reject the null hypothesis of a unit root for both series at the 1% level.
# Therefore, both total MLB home runs and total MLB strikeouts are treated
# as nonstationary.
# run regression
hr_on_k <- lm(hr_data~k_data)
summary(hr_on_k)
# The OLS regression produces an R-squared of 0.838. The p-value for the
# strikeout slope coefficient is less than 2e-16. Therefore, the regression
# produces a high R-squared and a highly statistically significant slope
# coefficient, despite both variables being nonstationary.
### Q2
# run ADF on OLS residuals
hr_on_k_residuals <- residuals(hr_on_k)
adf_residuals <- ur.df(
hr_on_k_residuals,
type = "none",
selectlags = "AIC"
)
summary(adf_residuals)
# In the Engle-Granger cointegration test, the null hypothesis is that the
# regression residuals are nonstationary, meaning that the two series are not
# cointegrated and the regression is spurious. The alternative hypothesis is
# that the residuals are stationary, meaning that the series are cointegrated.
# The residual ADF test statistic is -2.7291. Because the residuals were
# estimated from an OLS regression, this statistic must be compared with the
# Engle-Granger critical value rather than the standard tau1 critical value
# printed by ur.df().
# The sample contains 58 observations and the cointegrating regression includes
# two variables. Using the closest available and slightly more conservative
# sample size of T = 50 in the Engle-Granger table, the 1% critical value
# is -4.123.
# Because -2.7291 is not more negative than -4.123, I fail to reject the null
# hypothesis that the regression residuals are nonstationary.
# Therefore, total MLB home runs and total MLB strikeouts are not cointegrated
# at the 1% significance level. Despite the regression's high R-squared and
# statistically significant slope coefficient, the relationship is spurious.
# HW 5
# by Cole Geller
library(tidyverse)
library(urca)
# load data
setwd("C:/Users/coleg/OneDrive - UC San Diego/Spring 2026 Courses/Econ 112/HW 5/data")
# Data source: Lahman Baseball Database, Teams.csv.
# The sample begins in 1962, when both MLB leagues generally used a
# 162-game schedule, and ends in 2019 to exclude the shortened 2020 season.
teams_data <- read.csv("Teams.csv", header = TRUE, sep = ',')
mlb_time_series <- teams_data %>%
filter(yearID >= 1962, yearID <= 2019) %>%
group_by(yearID) %>%
summarise(
total_hr = sum(HR, na.rm = TRUE),
total_k = sum(SO, na.rm = TRUE),
.groups = 'drop'
)
hr_data <- ts(mlb_time_series$total_hr, start = 1962, frequency = 1)
k_data <- ts(mlb_time_series$total_k, start = 1962, frequency = 1)
### Q1
# plot data
plot(
hr_data,
type = 'l',
main = "Total MLB Home Runs",
xlab = "Year",
ylab = "Home Runs"
)
plot(
k_data,
type = 'l',
main = "Total MLB Strikeouts",
xlab = "Year",
ylab = "Strikeouts"
)
# test for non-stationarity
adf_hr <- ur.df(
hr_data,
type = "trend",
selectlags = "AIC"
)
adf_k <- ur.df(
k_data,
type = "trend",
selectlags = "AIC"
)
summary(adf_hr)
summary(adf_k)
# For home runs, the ADF tau3 statistic is -3.0356.
# For strikeouts, the ADF tau3 statistic is -2.0199.
# The 1% critical value is -4.04.
#
# Because neither test statistic is more negative than -4.04, I fail to
# reject the null hypothesis of a unit root for both series at the 1% level.
# Therefore, both total MLB home runs and total MLB strikeouts are treated
# as nonstationary.
# run regression
hr_on_k <- lm(hr_data~k_data)
summary(hr_on_k)
# The OLS regression produces an R-squared of 0.838. The p-value for the
# strikeout slope coefficient is low. Therefore, the regression
# produces a high R-squared and a highly statistically significant slope
# coefficient, despite both variables being nonstationary.
### Q2
# run ADF on OLS residuals
hr_on_k_residuals <- residuals(hr_on_k)
adf_residuals <- ur.df(
hr_on_k_residuals,
type = "none",
selectlags = "AIC"
)
summary(adf_residuals)
# In the Engle-Granger cointegration test, the null hypothesis is that the
# regression residuals are nonstationary, meaning that the two series are not
# cointegrated and the regression is spurious. The alternative hypothesis is
# that the residuals are stationary, meaning that the series are cointegrated.
# The residual ADF test statistic is -2.7291. Because the residuals were
# estimated from an OLS regression, this statistic must be compared with the
# Engle-Granger critical value rather than the standard tau1 critical value
# printed by ur.df().
# The sample contains 58 observations and the cointegrating regression includes
# two variables. Using the closest available sample size of T = 50 in the
# Engle-Granger table, the 1% critical value is -4.123.
# Because -2.7291 is not more negative than -4.123, I fail to reject the null
# hypothesis that the regression residuals are nonstationary.
# Therefore, total MLB home runs and total MLB strikeouts are not cointegrated
# at the 1% significance level. Despite the regression's high R-squared and
# statistically significant slope coefficient, the relationship is spurious.
source("C:/Users/coleg/OneDrive - UC San Diego/Spring 2026 Courses/Econ 112/HW 5/HW 5.R")
